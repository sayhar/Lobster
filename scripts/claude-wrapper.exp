#!/usr/bin/expect -f
#
# Claude wrapper script - Automatically accepts bypass permissions dialog
# and starts Claude with the Lobster main loop.
#
# Robustness notes:
# - Claude's interactive UI renders with ANSI escape codes. The ❯ prompt
#   character (U+276F) is matched via regex in a loop to handle cases where
#   the first render cycle contains the character before the UI is fully settled.
# - A 60s timeout gives plenty of headroom for slow startup (API calls,
#   auth checks, initial render).
# - We send the init prompt, sleep, then send a bare Enter in case the first
#   carriage return didn't register (observed intermittently on some terminals).
# - LOBSTER_MAIN_SESSION=1 is required by the MCP inbox_server session guard.
# - CLAUDE_CODE_SUBAGENT_MODEL and CLAUDE_AUTOCOMPACT_PCT_OVERRIDE set cost
#   and quality defaults inherited by all subagents.
#

set timeout 60

# Session isolation guard: mark this as the designated main Lobster session.
# The MCP inbox_server.py checks for this before allowing inbox monitoring and
# outbox writes.
set env(LOBSTER_MAIN_SESSION) 1

# Dispatcher runs on Sonnet for cost efficiency; subagents that don't specify
# an explicit model inherit this.
set env(CLAUDE_CODE_SUBAGENT_MODEL) sonnet

# Trigger context compaction at 80% capacity instead of default 95%.
set env(CLAUDE_AUTOCOMPACT_PCT_OVERRIDE) 80

# Start Claude with bypass permissions
spawn claude --dangerously-skip-permissions

# Wait for either the permissions dialog OR the ready prompt.
#
# The ❯ (U+276F) character appears in the prompt area surrounded by ANSI escape
# codes. Expect's regex engine sees the raw bytes (including escapes), so we
# match the Unicode codepoint directly. "Try \"" catches the welcome screen
# hint text as an alternative anchor.
#
# Note: the expect regex engine disables the "gate keeper" performance
# optimisation for Unicode patterns, so matching may take a few render cycles
# (each cycle is ~50 ms) — this is normal and harmless.
expect {
    "Yes, I accept" {
        # Permissions dialog appeared - navigate down to accept button and press Enter
        send "\033\[B"
        sleep 0.5
        send "\r"
        # Wait for the main prompt after dialog is dismissed
        expect {
            -re {❯|Try "} {
                # Prompt appeared — give the UI one more render cycle to settle
                sleep 2
            }
            timeout {
                puts "Timeout waiting for Claude prompt after permissions dialog"
                exit 1
            }
        }
    }
    -re {❯|Try "} {
        # Already at prompt - no dialog shown (--dangerously-skip-permissions active)
        # Give the UI one render cycle to settle before sending input
        sleep 2
    }
    timeout {
        puts "Timeout waiting for Claude to start (60s)"
        exit 1
    }
}

# Send the initialization command.
# This instructs Claude to read the project instructions and enter its main loop.
send "Read CLAUDE.md and begin your main loop. Call wait_for_messages to start listening for Telegram messages. Never exit.\r"

# Wait briefly for Claude to accept the input and begin processing.
# The render cycle after sending is ~100-300 ms; 3 s is generous.
sleep 3

# Safety: send a bare Enter in case the carriage return above was dropped
# (observed intermittently when the terminal emulator is still initialising).
send "\r"

# Hand over terminal control — Claude runs indefinitely.
# The expect process stays alive so the spawned claude process is not orphaned.
interact
