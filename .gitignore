# Credentials
.env
.env.*
*.env
!.env.example
!config.env.example
!mcp-http-auth.env.example
!bridge-local.example.env
config.env

# Python
__pycache__/
*.pyc
.venv/
venv/

# Node
node_modules/

# OS
.DS_Store
*.swp
*.swo

# Logs
*.log

# Generated service files (created from templates during install)
services/lobster-router.service
services/lobster-claude.service
services/lobster-mcp.service
services/lobster-slack-router.service

# Local configuration (use lobster.conf.example as template)
config/lobster.conf

# Runtime state (self-check rate limiting, etc.)
.state/

# Google Calendar credentials and tokens
config/google_credentials.json
config/calendar_tokens/
config/calendar_pending_flows/

# Runtime data (these dirs should not exist in the repo; kept as a safety net)
data/
memory/canonical/
memory/archive/digests/*.md

# Incident reports (generated at runtime by investigate-incident.sh)
incidents/*.md

# GSD framework (dev tooling, installed per-user)
.claude/agents/gsd-*.md
.claude/commands/
.claude/get-shit-done/
.claude/gsd-file-manifest.json
.claude/hooks/
.claude/package.json
.claude/settings.json

# Skill runtime data (PID files, local config)
config/camofox-browser/

# Planning artifacts
PLAN-*.md
.planning/

# Runtime workspace (inside repo, gitignored except structure markers)
# CWD for Claude Code sessions - CLAUDE.md is found by walking up from here
lobster-workspace/*
!lobster-workspace/.gitkeep
!lobster-workspace/.claude/
lobster-workspace/.claude/*
!lobster-workspace/.claude/agents/
lobster-workspace/.claude/agents/*
!lobster-workspace/.claude/agents/.gitkeep

# Secrets / external config (kept outside repo at ~/lobster-config/)
lobster-config/

# User customization files (directory tracked, contents ignored)
user/*
!user/.gitkeep
!user/agents/
user/agents/*
!user/agents/.gitkeep
!user/preferences/
user/preferences/*
!user/preferences/.gitkeep
